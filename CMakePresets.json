{
    "version": 3,
    "configurePresets": [
        {
            "name": "gpp-debug",
            "displayName": "g++ Debug",
            "description": "",
            "binaryDir": "${sourceDir}/build/debug",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS": "-g -masm=intel -std=c++23 -Wall"
            }
        },
        {
            "name": "gpp-release",
            "displayName": "g++ Release",
            "inherits": "gpp-debug",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "gpp-debug",
            "configurePreset": "gpp-debug"
        },
        {
            "name": "gpp-release",
            "configurePreset": "gpp-release"
        }
    ]
}
